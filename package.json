{
  "name": "cicd-practice-app",
  "version": "1.0.0",
  "description": "Sample app for GitHub Actions self-hosted runner CI/CD practice",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "jest --coverage",
    "lint": "eslint src/ tests/",
    "build": "node scripts/build.js"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    },
    "reporters": [
      "default",
      ["jest-junit", { "outputDirectory": "./test-results" }]
    ]
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^6.3.4"
  }
}
